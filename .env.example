# RetroLoop 環境変数テンプレート
# このファイルをコピーして .env（および Vercel の環境変数）に設定する。
#   cp .env.example .env
# .env は .gitignore 済み。実際の値はコミットしないこと。

# ── Database (Neon Postgres) ──────────────────
# Neon のダッシュボードから接続文字列を取得。末尾に ?sslmode=require が付く。
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ── Auth.js (NextAuth v5) ─────────────────────
# 生成: npx auth secret  （または openssl rand -base64 32）
AUTH_SECRET=""
# ローカルは http://localhost:3000 、本番は公開URL
AUTH_URL="http://localhost:3000"

# GitHub ログインを使う場合（GitHub OAuth App を作成して取得）
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── Anthropic Claude API ──────────────────────
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=""
