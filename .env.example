# RetroLoop 環境変数テンプレート
# このファイルをコピーして .env（および Vercel の環境変数）に設定する。
#   cp .env.example .env
# .env は .gitignore 済み。実際の値はコミットしないこと。

# ── Database (Neon Postgres) ──────────────────
# Neon のダッシュボード「Connection string」から取得。末尾に ?sslmode=require が付く。
# DATABASE_URL … アプリ実行用。ホスト名に "-pooler" が入った【プール接続】を使う。
# DIRECT_URL   … マイグレーション用。"-pooler" が【入っていない】直結接続を使う。
#   Neon の接続画面で "Pooled connection" のトグルを ON にした文字列が DATABASE_URL、
#   OFF にした文字列が DIRECT_URL（ホスト名以外は同じ）。
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ── Auth.js (NextAuth v5) ─────────────────────
# 生成: npx auth secret  （または openssl rand -base64 32）
AUTH_SECRET=""
# ローカルは http://localhost:3000 、本番は公開URL
AUTH_URL="http://localhost:3000"

# GitHub ログインを使う場合（GitHub OAuth App を作成して取得）
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ── Anthropic Claude API ──────────────────────
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=""
